<?xml version="1.0" encoding="utf-8"?>
<animated-selector xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt">
    <item android:state_checked="true" android:id="@+id/visible" android:drawable="@drawable/xq"/>
    <item android:id="@+id/masked" android:drawable="@drawable/xt"/>
    <transition android:drawable="@drawable/lu" android:toId="@+id/visible" android:fromId="@+id/masked"/>
    <transition android:drawable="@drawable/ll" android:toId="@+id/masked" android:fromId="@+id/visible"/>
</animated-selector>
