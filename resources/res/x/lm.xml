<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt">
    <item android:state_selected="false">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/mk"/>
            <solid android:color="@color/ma"/>
            <padding android:left="8dp" android:top="4dp" android:right="8dp" android:bottom="4dp"/>
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/mk"/>
            <solid android:color="@color/ml"/>
            <padding android:left="8dp" android:top="4dp" android:right="8dp" android:bottom="4dp"/>
        </shape>
    </item>
</selector>
