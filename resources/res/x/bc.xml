<?xml version="1.0" encoding="utf-8"?>
<animated-selector xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt">
    <item android:state_checked="true" android:id="@+id/checked" android:drawable="@drawable/oy"/>
    <item android:id="@+id/unchecked" android:drawable="@drawable/o1"/>
    <transition android:drawable="@drawable/o2" android:toId="@+id/checked" android:fromId="@+id/unchecked"/>
    <transition android:drawable="@drawable/o0" android:toId="@+id/unchecked" android:fromId="@+id/checked"/>
</animated-selector>
