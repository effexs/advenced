<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt">
    <item android:state_enabled="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/ed"/>
            <stroke android:width="1.5dp" android:color="@color/en"/>
            <corners android:radius="2dp"/>
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#fff1f1f1"/>
            <stroke android:width="1.5dp" android:color="#ffe3e3e3"/>
            <corners android:radius="2dp"/>
        </shape>
    </item>
</selector>
